DRY_RUN=true
BNBCHAIN_MCP_ENABLED=false
BNBCHAIN_MCP_COMMAND=npx
BNBCHAIN_MCP_ARGS=-y @bnb-chain/mcp@latest
BNBCHAIN_MCP_NETWORK=bsc-testnet
BNBCHAIN_REFERENCE_TOKEN=
DARK_MATTER_NETWORK=bsc-testnet
DARK_MATTER_TRANSCRIPT_SECRET=replace-me
DARK_MATTER_RPC_URL=
DARK_MATTER_DEPLOYER_PRIVATE_KEY=
DARK_MATTER_AGENT_A_ADDRESS=
DARK_MATTER_AGENT_B_ADDRESS=
DARK_MATTER_AGENT_A_PRIVATE_KEY=
DARK_MATTER_AGENT_B_PRIVATE_KEY=
DARK_MATTER_OPERATOR_PRIVATE_KEY=
DARK_MATTER_CHAIN_ID=
# Optional override (defaults to project_root/contracts)
DARK_MATTER_CONTRACTS_DIR=
# Transcript store mode: memory | file
DARK_MATTER_TRANSCRIPT_STORE=memory
# Used when DARK_MATTER_TRANSCRIPT_STORE=file
DARK_MATTER_TRANSCRIPT_FILE=/tmp/agentic-dark-matter-transcripts.json
# Action graph store mode: memory | file
DARK_MATTER_ACTION_GRAPH_STORE=memory
# Used when DARK_MATTER_ACTION_GRAPH_STORE=file
DARK_MATTER_ACTION_GRAPH_FILE=/tmp/agentic-dark-matter-action-graphs.json
# Settlement mode: standard | timeout-claim
DARK_MATTER_SETTLEMENT_MODE=standard
# MCP wrapper target for operator controls
DARK_MATTER_OPERATOR_API_URL=http://127.0.0.1:3000
# Demo-only switch to simulate sealed side-channel coordination lines
DARK_MATTER_ALLOW_SECRET_COLLUSION=false
