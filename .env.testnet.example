DRY_RUN=false
BNBCHAIN_MCP_ENABLED=false
BNBCHAIN_MCP_NETWORK=bsc-testnet
BNBCHAIN_REFERENCE_TOKEN=

DARK_MATTER_NETWORK=bsc-testnet
DARK_MATTER_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
DARK_MATTER_CHAIN_ID=97

# ─── 3-Wallet Setup ───────────────────────────────────────────────────────────
# For the RFQ marketplace demo (demo:up:testnet) you need 3 funded wallets:
#
#   Wallet 1  →  DEPLOYER + AGENT_A + OPERATOR  (coordinator — holds escrow + gas)
#   Wallet 2  →  AGENT_B                         (executor — Telegram persona)
#   Wallet 3  →  AGENT_C                         (executor — Discord persona)
#
# Each executor only needs ~0.01 BNB for approval gas across a few cycles.
# Wallet 1 needs escrow amount (DARK_MATTER_LIQUIDITY_BNB) + deploy/release gas per cycle.
#
# Run the distribution helper to check balances (and optionally top up):
#   node ./scripts/fund-testnet-agents.mjs --env .env.testnet
# ─────────────────────────────────────────────────────────────────────────────

# Wallet 1: deployer/coordinator (must hold escrow amount + deployment gas)
DARK_MATTER_DEPLOYER_PRIVATE_KEY=
DARK_MATTER_AGENT_A_PRIVATE_KEY=   # same key as DEPLOYER
DARK_MATTER_OPERATOR_PRIVATE_KEY=  # same key as DEPLOYER
DARK_MATTER_AGENT_A_ADDRESS=

# Wallet 2: Agent B executor (Telegram persona — approval gas only)
DARK_MATTER_AGENT_B_PRIVATE_KEY=
DARK_MATTER_AGENT_B_ADDRESS=

# Wallet 3: Agent C executor (Discord persona — approval gas only)
DARK_MATTER_AGENT_C_PRIVATE_KEY=
DARK_MATTER_AGENT_C_ADDRESS=

# ─── Escrow amount ────────────────────────────────────────────────────────────
# This is the BNB locked in escrow per agreement. Keep low while on testnet.
# With 0.6 BNB total: 0.05 gives ~10 agreement cycles before needing more faucet.
DARK_MATTER_LIQUIDITY_BNB=0.05

# RFQ: set false so ALL executors (Agent B + Agent C) can bid. Set true to restrict.
DARK_MATTER_RFQ_STRICT_AGENT_B=false

DARK_MATTER_TRANSCRIPT_SECRET=replace-me-with-random-secret
DARK_MATTER_TRANSCRIPT_STORE=file
DARK_MATTER_TRANSCRIPT_FILE=/tmp/agentic-dark-matter-transcripts-bsc-testnet.json
DARK_MATTER_ACTION_GRAPH_STORE=file
DARK_MATTER_ACTION_GRAPH_FILE=/tmp/agentic-dark-matter-action-graphs-bsc-testnet.json
DARK_MATTER_SETTLEMENT_MODE=standard
DARK_MATTER_OPERATOR_API_URL=http://127.0.0.1:3000

# Optional override (defaults to project_root/contracts)
DARK_MATTER_CONTRACTS_DIR=