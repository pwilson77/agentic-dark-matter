# Vercel environment variables for dark-matter-ui
# Set these in the Vercel dashboard under Project → Settings → Environment Variables

# ── Network ──────────────────────────────────────────────────────────────────
# Public BSC testnet RPC (no key required) or your private node
DARK_MATTER_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
DARK_MATTER_NETWORK=bsc-testnet
DARK_MATTER_CHAIN_ID=97

# Block to start scanning from.
# Set this to just before your first DarkMatterEscrow deployment to avoid scanning all history.
# Contract 0xc277822Db6A6b3040609af78836d6e8ad88f1c84 was deployed around block 103070560 on BSC testnet.
# Verify/update at: https://testnet.bscscan.com/address/0xc277822Db6A6b3040609af78836d6e8ad88f1c84
DARK_MATTER_LOCAL_FROM_BLOCK=103070560

# ── Indexing strategy ────────────────────────────────────────────────────────
# "chain"  → read agreements from on-chain getLogs (correct for Vercel; no state file)
# "state"  → read from local /tmp state file (only works on same machine as agents)
DARK_MATTER_LOCAL_SOURCE=chain
DARK_MATTER_POOL_SOURCE=local

# ── Agent addresses (for display in dashboard) ───────────────────────────────
DARK_MATTER_AGENT_A_ADDRESS=
DARK_MATTER_AGENT_B_ADDRESS=

# ── Operator key (for the /api/session/action route — approve/release buttons) ─
# WARNING: Only set this if you want the dashboard to be able to sign transactions.
# Leave empty to make the dashboard read-only.
DARK_MATTER_OPERATOR_PRIVATE_KEY=
